# Microsoft Azure App Registration
CLIENT_ID=Client ID from Azure App Registration
TENANT_ID=Tenant ID from Azure App Registration
CLIENT_SECRET=Client Secret from Azure App Registration
CLIENT_SECRET_ID=Client Secret ID from Azure App Registration
REDIRECT_URI=http://localhost:3000/auth/callback

# Session
SESSION_SECRET=change_this_to_a_random_secret

# Claude API — choose ONE of the two options below:

# Option A: Azure AI Foundry (recommended for competition)
# Deploy Claude from ai.azure.com → Model catalog → Claude Sonnet → Serverless API
# Then copy the endpoint URL and Key 1 from the deployment page.
# Paste the Target URI from your Azure deployment, then remove the trailing /v1/messages
# Example: Target URI = https://your-resource.services.ai.azure.com/anthropic/v1/messages
#          → set AZURE_INFERENCE_ENDPOINT = https://your-resource.services.ai.azure.com/anthropic
AZURE_INFERENCE_ENDPOINT=your_azure_inference_endpoint
AZURE_INFERENCE_KEY=your_azure_inference_key

# Option B: Direct Anthropic (app already uses Azure via MSAL/Graph — this still qualifies)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
PORT=3000
